/**
 * AyosPH - Supabase Configurati * Initialize and export Supabase client
 */

// Supabase Configuration
const SUPABASE_URL = 'YOUR_SUPABASE_URL';
const SUPABASE_KEY = 'YOUR_SUPABASE_ANON_KEY';

// Validate environment variables
if (!SUPABASE_URL || !SUPABASE_KEY) {
    console.warn('⚠️ Supabase credentials not configured. Please set SUPABASE_URL and SUPABASE_KEY');
}

/**
 * Initialize Supabase Client
 * Use this pattern to initialize: const { data, error } = await supabase.from('table').select()
 */
class SupabaseClient {
    constructor() {
        this.url = SUPABASE_URL;
        this.key = SUPABASE_KEY;
        this.headers = {
            'Content-Type': 'application/json',
            'apikey': this.key,
            'Authorization': `Bearer ${this.key}`
        };
    }

    /**
     * Perform a GET request to Supabase
     */
    async get(table, query = '') {
        try {
            const url = new URL(`${this.url}/rest/v1/${table}`);
            if (query) url.search = query;

            const response = await fetch(url, {
                method: 'GET',
                headers: this.headers
            });

            if (!response.ok) {
                throw new Error(`Supabase error: ${response.status}`);
            }

            return await response.json();
        } catch (error) {
            console.error('Supabase GET error:', error);
            throw error;
        }
    }

    /**
     * Perform a POST request to Supabase
     */
    async post(table, data) {
        try {
            const response = await fetch(`${this.url}/rest/v1/${table}`, {
                method: 'POST',
                headers: this.headers,
                body: JSON.stringify(data)
            });

            if (!response.ok) {
                throw new Error(`Supabase error: ${response.status}`);
            }

            return await response.json();
        } catch (error) {
            console.error('Supabase POST error:', error);
            throw error;
        }
    }

    /**
     * Perform a PATCH request to Supabase
     */
    async patch(table, id, data) {
        try {
            const response = await fetch(`${this.url}/rest/v1/${table}?id=eq.${id}`, {
                method: 'PATCH',
                headers: this.headers,
                body: JSON.stringify(data)
            });

            if (!response.ok) {
                throw new Error(`Supabase error: ${response.status}`);
            }

            return await response.json();
        } catch (error) {
            console.error('Supabase PATCH error:', error);
            throw error;
        }
    }

    /**
     * Perform a DELETE request to Supabase
     */
    async delete(table, id) {
        try {
            const response = await fetch(`${this.url}/rest/v1/${table}?id=eq.${id}`, {
                method: 'DELETE',
                headers: this.headers
            });

            if (!response.ok) {
                throw new Error(`Supabase error: ${response.status}`);
            }

            return { success: true };
        } catch (error) {
            console.error('Supabase DELETE error:', error);
            throw error;
        }
    }

    /**
     * Authentication - Sign Up
     */
    async signUp(email, password, userData = {}) {
        try {
            const response = await fetch(`${this.url}/auth/v1/signup`, {
                method: 'POST',
                headers: this.headers,
                body: JSON.stringify({
                    email,
                    password,
                    user_metadata: userData
                })
            });

            const data = await response.json();

            if (!response.ok) {
                throw new Error(data.message || 'Signup failed');
            }

            return data;
        } catch (error) {
            console.error('Signup error:', error);
            throw error;
        }
    }

    /**
     * Authentication - Sign In
     */
    async signIn(email, password) {
        try {
            const response = await fetch(`${this.url}/auth/v1/token?grant_type=password`, {
                method: 'POST',
                headers: this.headers,
                body: JSON.stringify({
                    email,
                    password
                })
            });

            const data = await response.json();

            if (!response.ok) {
                throw new Error(data.message || 'Login failed');
            }

            // Store session
            if (data.session) {
                localStorage.setItem('ayosph_session', JSON.stringify(data.session));
            }

            return data;
        } catch (error) {
            console.error('Login error:', error);
            throw error;
        }
    }

    /**
     * Authentication - Sign Out
     */
    async signOut() {
        localStorage.removeItem('ayosph_session');
        return { success: true };
    }

    /**
     * Get current session
     */
    getSession() {
        const session = localStorage.getItem('ayosph_session');
        return session ? JSON.parse(session) : null;
    }

    /**
     * Check if user is authenticated
     */
    isAuthenticated() {
        const session = this.getSession();
        return !!session && !!session.access_token;
    }

    /**
     * Upload file to Supabase Storage
     */
    async uploadFile(bucket, filename, file) {
        try {
            const formData = new FormData();
            formData.append('', file);

            const session = this.getSession();
            const headers = {
                'apikey': this.key,
                'Authorization': session ? `Bearer ${session.access_token}` : `Bearer ${this.key}`
            };

            const response = await fetch(
                `${this.url}/storage/v1/object/${bucket}/${filename}`,
                {
                    method: 'POST',
                    headers: headers,
                    body: formData
                }
            );

            if (!response.ok) {
                throw new Error(`Upload error: ${response.status}`);
            }

            return { success: true, path: `${bucket}/${filename}` };
        } catch (error) {
            console.error('Upload error:', error);
            throw error;
        }
    }

    /**
     * Get public URL for uploaded file
     */
    getPublicUrl(bucket, path) {
        return `${this.url}/storage/v1/object/public/${bucket}/${path}`;
    }
}

// Create and export the Supabase client instance
const supabase = new SupabaseClient();

